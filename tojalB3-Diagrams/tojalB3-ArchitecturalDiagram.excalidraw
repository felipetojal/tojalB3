      "link": null,
      "locked": false,
      "text": "This struct is responsible for\nmanaging the volume file. It\ncontains a bit map that indicates\nwhich spots are free, allowing\nsafe storage.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "-dis3m4zQmVEqRc4olqlL",
      "originalText": "This struct is responsible for managing the volume file. It contains a bit map that indicates which spots are free, allowing safe storage.",
      "autoResize": true,
      "lineHeight": 1.25
    },
