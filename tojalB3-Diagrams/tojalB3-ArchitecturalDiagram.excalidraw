      "updated": 1776435449885,
      "link": null,
      "locked": false,
      "text": "To avoid storing the same file\ntwice, we´ll use this index\nmethod. The hash generated will\nindicate the block content and\nthe address will be pointing to\nthe position in the volume",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "aztVwJdDgrpHhoRkjSA4L",
      "originalText": "To avoid storing the same file twice, we´ll use this index method. The hash generated will indicate the block content and the address will be pointing to the position in the volume",
      "autoResize": true,
      "lineHeight": 1.25
    },
